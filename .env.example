# ── Server ─────────────────────────────────────────────
PORT=3000
# Must be a public HTTPS URL in production (Twilio + Stripe webhooks need to reach it)
PUBLIC_URL=http://localhost:3000

# ── AI agent (optional — falls back to built-in rules engine) ──
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Twilio: real phone calls + SMS (optional — demo simulator works without) ──
# 1. Buy a number at https://console.twilio.com
# 2. Set the number's Voice webhook to: POST {PUBLIC_URL}/voice/incoming
# 3. Set the Status callback to:        POST {PUBLIC_URL}/voice/status
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── ElevenLabs: premium conversational AI voice (optional) ──
# Replaces Twilio STT + Polly TTS with ElevenLabs Conversational AI
# 1. Get an API key at https://elevenlabs.io
# 2. Choose or clone a voice and copy its Voice ID
# 3. Start server → hit POST /api/el/setup to create the agent
# 4. Import your Twilio number into ElevenLabs dashboard and link to the agent
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# ── Shopify: payment links (optional — takes priority over Stripe when set) ──
# Paste the buy-button / checkout URL for each service from your Shopify admin.
# Use underscores in the env var name: SHOPIFY_URL_WRITE_GRANT → maps to fee code WRITE-GRANT
# Any codes without a URL will fall through to Stripe or demo mode.
SHOPIFY_URL_GRANT_READY=
SHOPIFY_URL_WRITE_GRANT=
SHOPIFY_URL_BIZ_PLAN=
SHOPIFY_URL_GRANT_CERT=
SHOPIFY_URL_STRATEGY=

# ── Stripe: real payments (optional — used if Shopify URLs are not set) ──
# Get keys at https://dashboard.stripe.com/apikeys
# Webhook: add endpoint {PUBLIC_URL}/webhooks/stripe listening to checkout.session.completed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
